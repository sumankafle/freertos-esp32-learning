## Ignore build artifacts and generated files for ESP-IDF projects

# Build directories
/build/
**/build/

# CMake files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile
compile_commands.json

# SDK config (generated)
sdkconfig
sdkconfig.ci
sdkconfig.old

# Binary outputs
*.bin
*.elf
*.map
*.hex

# Partition table / flash args
flash_args
flash_args.in
flasher_args.json
app-flash_args
bootloader-flash_args
flash_app_args
flash_bootloader_args
flash_project_args
partition-table-flash_args

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# Editor/IDE
.vscode/
*.code-workspace

# Local environment / tools
.espressif/
/.espressif/
config.env

# Temporary and backup files
*~
.DS_Store
